# Runtime
NODE_ENV=development
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE
ADMIN_SESSION_SECRET=replace-with-a-long-random-string

# Telegram booking alerts
TELEGRAM_BOT_TOKEN=123456789:replace_with_bot_token
TELEGRAM_CHAT_ID=123456789

# Frontend API endpoint. Required when the frontend is hosted on GitHub Pages
# and the backend is deployed on another host.
VITE_TRPC_URL=http://localhost:3000/api/trpc

# Optional notification channels
GOOGLE_SHEETS_CREDENTIALS=
GOOGLE_SHEETS_ID=
LINE_CHANNEL_ACCESS_TOKEN=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ADMIN_EMAIL=

# Optional platform/runtime values
JWT_SECRET=
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
